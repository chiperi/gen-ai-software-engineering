# Environment variables (neutral — no real secrets committed). Copy to .env for local dev.
APP_ENV=development
# PostgreSQL DSN
DATABASE_URL=postgresql://cards:cards@localhost:5432/cards
# External services (referenced by the lifecycle service; see spec §8)
VAULT_BASE_URL=
KYC_BASE_URL=
FUNDING_BASE_URL=
FRAUD_BUS_URL=
IDENTITY_BASE_URL=
# Idempotency key retention (hours) — ADR-0003
IDEMPOTENCY_TTL_HOURS=24
# Audit retention (years) — constitution P3 / NFR-014
AUDIT_RETENTION_YEARS=7
